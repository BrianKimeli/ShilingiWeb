{
    "rewrites": [
      {
        "source": "/",
        "has": [
          {
            "type": "host",
            "value": "shilingitimes.vercel.app"
          }
        ],
        "destination": "/times"
      },
      {
        "source": "/((?!_next/static|_next/image|favicon.ico|api).*)",
        "has": [
          {
            "type": "host",
            "value": "shilingitimes.vercel.app"
          }
        ],
        "destination": "/times/:1"
      }
    ]
  }